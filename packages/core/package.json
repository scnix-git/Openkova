{
  "name": "@openkova/core",
  "version": "0.2.1",
  "description": "HTML to image/PDF engine powered by Puppeteer. Render snippets, local HTML files, or live URLs to PNG, JPEG, WebP, or PDF — with configurable viewport, full-page capture, and pluggable storage.",
  "keywords": [
    "html-to-image",
    "html-to-png",
    "html-to-pdf",
    "screenshot",
    "puppeteer",
    "headless-chrome",
    "html-screenshot",
    "webpage-screenshot",
    "url-to-image",
    "pdf-generator"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scnix-git/Openkova.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/scnix-git/Openkova#readme",
  "bugs": {
    "url": "https://github.com/scnix-git/Openkova/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --experimental-vm-modules --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "puppeteer-core": "^25.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "puppeteer": "^25.1.0",
    "typescript": "^5.0.0"
  }
}
