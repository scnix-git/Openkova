{
  "name": "openkova",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @openkova/core build && pnpm --filter @openkova/web build",
    "dev": "pnpm --filter @openkova/core build && pnpm --filter @openkova/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "baseline-browser-mapping": "<=2.10.32"
    }
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
